# Async SQLAlchemy database URL for local Postgres.
DATABASE_URL=postgresql+asyncpg://novel:novel@127.0.0.1:5432/novel_translate

# Redis URL for API and arq worker.
REDIS_URL=redis://127.0.0.1:6379/0

# MinIO S3-compatible endpoint used for object storage.
MINIO_ENDPOINT=http://127.0.0.1:9000

# MinIO access key for local development.
MINIO_ACCESS_KEY=novel

# MinIO secret key for local development.
MINIO_SECRET_KEY=novel_password

# MinIO bucket for imported files and exports.
MINIO_BUCKET=novel-translate

# Default translation provider kind.
NT_PROVIDER_KIND=openai_compatible

# OpenAI-compatible API base URL.
OPENAI_BASE_URL=http://127.0.0.1:11434/v1

# OpenAI-compatible API key.
OPENAI_API_KEY=

# OpenAI-compatible model name.
OPENAI_MODEL=

# Anthropic API key.
ANTHROPIC_API_KEY=

# Anthropic model name.
ANTHROPIC_MODEL=claude-sonnet-4-6
